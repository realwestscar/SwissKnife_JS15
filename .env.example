# Environment
NODE_ENV=development
VERCEL_ENV=development

# Security
# JWT_SECRET must be at least 32 characters
JWT_SECRET=your-super-secret-key-change-in-production-32chars
# REFRESH_TOKEN_PEPPER should be at least 16 characters and rotated independently from JWT_SECRET
REFRESH_TOKEN_PEPPER=refresh-token-pepper-change-me
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database (required unless ALLOW_IN_MEMORY_DB=true)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/swissknife

# Upstash Redis (required unless ALLOW_IN_MEMORY_RATE_LIMIT=true)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100

# Local/test fallback flags. Never set these true in production.
# ALLOW_IN_MEMORY_SERVICES enables all in-memory fallback services.
ALLOW_IN_MEMORY_SERVICES=false
ALLOW_IN_MEMORY_DB=false
ALLOW_IN_MEMORY_RATE_LIMIT=false

# Optional observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Internal build verification toggle (used by build:verify script)
BUILD_VERIFY=false

# TRUST_PROXY note:
# If deployed behind a load balancer, ensure it sets x-forwarded-for.
# If deployed directly, IP-based rate limiting is not reliable.
